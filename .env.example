# Copy to .env and set a real password (scripts/setup-neo4j.sh does this for you).
# .env is gitignored; never commit real credentials.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Do NOT set ANTHROPIC_API_KEY or ANTHROPIC_AUTH_TOKEN here. Argus is
# subscription-only by hard rule: it authenticates Claude via the logged-in
# `claude` CLI and strips these vars before every call so it can never spend
# pay-per-use API credits. A key placed here would simply be ignored.
