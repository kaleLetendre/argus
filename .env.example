# Copy to .env and fill in real values. .env is gitignored; never commit credentials.

# Neo4j (the graph memory's store)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Model connection (user-configured, D25): agents call whatever connection you
# wire up here (a local model, an inference server, a hosted API, a
# subscription-backed CLI). Nothing is billable unless you configure a billable
# connection.
# ARGUS_LLM_PROVIDER=claude | gemini
# ARGUS_LLM_MODEL=opus | gemini-1.5-pro | ...
# ARGUS_SYSTEM_PROMPT="You are Argus, a garage assistant."
ARGUS_LLM_PROVIDER=claude
ARGUS_LLM_MODEL=opus
ARGUS_SYSTEM_PROMPT=""
